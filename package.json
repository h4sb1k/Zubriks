{
  "name": "Zubriki",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "b": "pnpm --filter @Zubriki/backend",
    "f": "pnpm --filter @Zubriki/frontend",
    "dev": "pnpm -r --parallel dev",
    "types": "concurrently 'pnpm w types' 'pnpm b types'",
    "prettify": "pnpm -r --parallel prettify",
    "lint": "concurrently 'pnpm b lint' 'pnpm w lint'",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },

  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-config-love": "^154.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "backend/**/*.{js,ts}": [
      "pnpm --filter @Zubriki/backend lint --fix"
    ],
    "frontend/**/*.{js,ts,tsx}": [
      "pnpm --filter @Zubriki/frontend lint --fix"
    ]
  },
  "dependencies": {
    "include-media": "^2.0.0"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
