generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  emailVerified      Boolean           @default(false)
  passwordHash       String?
  name               String?
  avatarUrl          String?
  role               Role              @default(USER)
  totpSecret         String?
  totpEnabled        Boolean           @default(false)
  tokenVersion       Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  oauthAccounts      OAuthAccount[]
  refreshTokens      RefreshToken[]
  createdRoutes      Route[]           @relation("RouteAuthor")
  achievements       UserAchievement[]
  routeInteractions  UserRoute[]
  completedWaypoints UserWaypoint[]
  unlockedZubriks    UserZubrik[]
  adminAuditLogs     AdminAuditLog[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Zubrik {
  id           String       @id @default(cuid())
  name         String
  description  String
  imageUrl     String?
  latitude     Float
  longitude    Float
  locationName String
  createdAt    DateTime     @default(now())
  unlockedBy   UserZubrik[]
}

model UserZubrik {
  userId     String
  zubrikId   String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  zubrik     Zubrik   @relation(fields: [zubrikId], references: [id], onDelete: Cascade)

  @@id([userId, zubrikId])
}

model Event {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  time      String
  venue     String
  category  String
  price     String?
  imageUrl  String?
  url       String?
  createdAt DateTime @default(now())

  @@index([date])
}

model Route {
  id               String      @id @default(cuid())
  name             String
  distance         String
  duration         String
  description      String?
  imageColor       String?
  icon             String?
  imageUrl         String?
  isMain           Boolean     @default(false)
  authorId         String?
  createdAt        DateTime    @default(now())
  author           User?       @relation("RouteAuthor", fields: [authorId], references: [id])
  userInteractions UserRoute[]
  waypoints        Waypoint[]
}

model Waypoint {
  id          String         @id @default(cuid())
  routeId     String
  name        String
  description String?
  icon String?
  latitude    Float
  longitude   Float
  orderIndex  Int
  completedBy UserWaypoint[]
  route       Route          @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
}

model UserRoute {
  userId      String
  routeId     String
  liked       Boolean   @default(false)
  startedAt   DateTime?
  completedAt DateTime?
  route       Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, routeId])
  @@index([userId])
}

model UserWaypoint {
  userId      String
  waypointId  String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  waypoint    Waypoint @relation(fields: [waypointId], references: [id], onDelete: Cascade)

  @@id([userId, waypointId])
}

model Achievement {
  id              String            @id @default(cuid())
  name            String
  description     String
  imageUrl        String
  icon String?
  conditionType   String            @default("MANUAL")
  conditionTarget String?
  conditionCount  Int               @default(1)
  users           UserAchievement[]
}

model UserAchievement {
  userId        String
  achievementId String
  earned        Boolean     @default(false)
  progress      Int         @default(0)
  isPinned      Boolean     @default(false)
  pinnedAt      DateTime?
  earnedAt      DateTime?
  pinOrder      Int         @default(0)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@index([userId])
}

enum Role {
  USER
  ADMIN
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String   // e.g. "adminDeleteRoute", "adminLogin"
  resource  String?  // Optional resource ID or name being acted upon
  details   Json?    // Any additional input details or changes
  ipAddress String?
  createdAt DateTime @default(now())

  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}
