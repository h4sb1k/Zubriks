{
  "name": "@Zubriki/backend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "tsx watch ./src/index.ts",
    "build": "rimraf ./dist && tsc",
    "start": "node ./dist/index.js",
    "prettify": "prettier --log-level warn --cache --write '{**/src/**/*,*}.{ts,tsx,js,json,yml,scss,css}' '!**/{node_modules,dist}/**/*'",
    "types": "tsc --noEmit --project ./tsconfig.json",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/.eslintcache ."
  },
  "dependencies": {
    "@trpc/server": "^11.17.0",
    "Express": "^3.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lodash": "^4.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4"
  }
}
